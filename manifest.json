{
  "manifest_version": 3,
  "name": "BookLogic Studio",
  "version": "0.4.0",
  "description": "PDF study assistant — select text and push to sidebar panel",
  "permissions": ["sidePanel", "activeTab", "contextMenus", "storage", "scripting"],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {},
  "optional_permissions": [],
  "host_permissions": ["<all_urls>"]
}
